# Copy this file to .env and fill in your real MetaTrader 5 account details.
# Never commit the real .env file.

MT5_LOGIN=12345678
MT5_PASSWORD=change-me
MT5_SERVER=YourBroker-Demo
# Full path to terminal64.exe, only needed if MT5 isn't already running.
MT5_TERMINAL_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
